# ============================================================
# Support Ticket Issue Intelligence System — Backend Config
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role key — bypasses Row Level Security (for server-side scripts only)
# Found under: Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── OpenAI ────────────────────────────────────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
