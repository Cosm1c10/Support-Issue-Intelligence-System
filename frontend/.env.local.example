# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase project URL (found in Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key — bypasses RLS, keep this secret
SUPABASE_SERVICE_KEY=eyJ...

# OpenAI API key — used for embeddings (text-embedding-3-small) and GPT-4o-mini summaries
OPENAI_API_KEY=sk-proj-...

# Optional: shared secret for POST /api/webhooks/incoming-ticket
# If set, the endpoint requires the header: x-webhook-secret: <value>
WEBHOOK_SECRET=

# Optional: shared secret for POST /api/recluster
# If set, the endpoint requires the header: x-sync-secret: <value>
SYNC_SECRET=
